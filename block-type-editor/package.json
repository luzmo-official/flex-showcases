{
  "name": "reporting-editorjs-builder",
  "version": "0.0.1-alpha.1",
  "description": "Report builder with Editor.js, Luzmo Lucero and Analytics Components Kit",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:ci": "tsc && vite build --base=/block-type-editor/",
    "preview": "vite preview",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src --write",
    "format:check": "oxfmt src --check"
  },
  "author": "Karel Callens",
  "dependencies": {
    "@editorjs/editorjs": "^2.31.0",
    "@editorjs/list": "^2.0.8",
    "@luzmo/analytics-components-kit": "1.0.1",
    "@luzmo/embed": "^6.9.0",
    "@luzmo/icons": "^1.0.1-alpha.31",
    "@luzmo/lucero": "^1.0.1-alpha.60"
  },
  "devDependencies": {
    "oxfmt": "^0.23.0",
    "oxlint": "^1.38.0",
    "sass": "^1.89.1",
    "typescript": "^5.8.3",
    "ultracite": "^7.0.8",
    "vite": "^8.0.0-beta.6"
  }
}

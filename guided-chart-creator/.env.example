# Comma-separated dataset UUIDs to load in the builder
NEXT_PUBLIC_LUZMO_DATASET_IDS=dataset-uuid-1,dataset-uuid-2

# Luzmo app server URL
NEXT_PUBLIC_LUZMO_APP_SERVER=https://app.luzmo.com

# Luzmo API host (EU default; use https://api.us.luzmo.com for US)
NEXT_PUBLIC_LUZMO_API_HOST=https://api.luzmo.com

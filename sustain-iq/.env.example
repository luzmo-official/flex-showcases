# Luzmo embed credentials (generate once via the Authorization API)
# See: https://developer.luzmo.com/api/createAuthorization.md
VITE_LUZMO_EMBED_KEY=your-embed-auth-key
VITE_LUZMO_EMBED_TOKEN=your-embed-auth-token

# Luzmo API host (default: https://api.luzmo.com & https://app.luzmo.com)
VITE_LUZMO_API_HOST=https://api.luzmo.com
VITE_LUZMO_APP_SERVER=https://app.luzmo.com

# Dataset UUID (from Luzmo UI: Datasets → Settings)
VITE_LUZMO_DATASET_ID=your-dataset-uuid

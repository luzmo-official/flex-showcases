# Embedding credentials for Luzmo Flex/Embed.
# See: https://developer.luzmo.com/guide/dashboard-embedding--generating-an-authorization-token
# Create an embedding API key and token in the Luzmo app; the token must have "use" rights over
# the datasets referenced below (VITE_LUZMO_DATASET_*).
VITE_LUZMO_EMBED_KEY=your-embed-key-here
VITE_LUZMO_EMBED_TOKEN=your-embed-token-here

VITE_LUZMO_APP_SERVER=https://app.luzmo.com
VITE_LUZMO_API_HOST=https://api.luzmo.com
VITE_LUZMO_DATASET_GROUPS_ODDS=your-dataset-id-here
VITE_LUZMO_DATASET_TEAM_PROFILES=your-dataset-id-here
VITE_LUZMO_DATASET_HISTORICAL=your-dataset-id-here

# Optional: column IDs for built-in reports and Pitch fallback charts (no API call from browser).
# Fill these using the Luzmo Node SDK (e.g. search columns for the Groups/Odds dataset).
# VITE_LUZMO_COLUMN_TEAM=
# VITE_LUZMO_COLUMN_GROUP=
# VITE_LUZMO_COLUMN_TOURNAMENT_WIN_PROB=
# VITE_LUZMO_COLUMN_GROUP_ADVANCE_PROB=
# VITE_LUZMO_COLUMN_GROUP_WIN_PROB=
# VITE_LUZMO_COLUMN_CONFEDERATION=
